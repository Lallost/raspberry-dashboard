mperatura:</strong> <span id="temp"></span></p>
        <p><strong>Disco:</strong> <span id="disk"></span></p>
        <p><strong>Uptime:</strong> <span id="uptime"></span></p>
        <p><strong>Navidrome:</strong> <span id="navidrome" class="status-badge"></span></p>
        <p><strong>Syncthing:</strong> <span id="syncthing" class="status-badge"></span></p>
    </div>

    <script>
        async function update() {
            const res = await fetch("/api/status");
            const data = await res.json();

            setCpu(data.cpu);
            document.getElementById("temp").textContent = data.temp;
            document.getElementById("disk").textContent = data.disk;
            document.getElementById("uptime").textContent = data.uptime;

            function setStatus(id, value) {
                const el = document.getElementById(id);
                el.textContent = value;

                el.classList.remove("status-active", "status-inactive", "status-error");

                if (value === "active") {
                    el.classList.add("status-active");
                } else if (value === "inactive") {
                    el.classList.add("status-inactive");
                } else {
                    el.classList.add("status-error");
                }
            }

            function setCpu(value) {
                const el = document.getElementById("cpu");
                el.textContent = value;

                // Estrae la percentuale di utilizzo (us + sy)
                const match = value.match(/([0-9.]+)\s+us,\s+([0-9.]+)\s+sy/);
                if (!match) {
                    el.classList.add("status-error");
                    return;
                }

                const user = parseFloat(match[1]);
                const system = parseFloat(match[2]);
                const usage = user + system;

                el.classList.remove("status-active", "status-inactive", "status-error");

                if (usage < 40) {
                    el.classList.add("status-active");   // verde
                } else if (usage < 75) {
                    el.classList.add("status-inactive"); // rosso chiaro (usiamo rosso per ora)
                } else {
                    el.classList.add("status-error");    // grigio scuro = carico alto
                }
            }

            setStatus("navidrome", data.navidrome);
            setStatus("syncthing", data.syncthing);
        }

        update();
        setInterval(update, 3000);
    </script>
</body>
</html>
